#!/bin/bash

APP_DIR="$1"
ENV_DIR="$3"

# load required environment variables
GIT_REPO_URL=$(<"$ENV_DIR/GIT_REPO_URL")
GIT_SSH_KEY=$(<"$ENV_DIR/GIT_SSH_KEY")


if [[ -z $GIT_REPO_URL ]]; then
    echo "Did you forget to set GIT_REPO_URL?"
    exit 1
else
    echo "GIT_REPO_URL is set to $GIT_REPO_URL"
fi

if [[ -z $GIT_SSH_KEY ]]; then
    echo "Did you forget to set GIT_SSH_KEY?"
    exit 1
else
    echo "GIT_SSH_KEY is set. Make sure that line breaks are valid and new line is at the end"
fi

if [ -f "$ENV_DIR/GIT_SSH_CRYPTO_FILENAME" ]; then
    GIT_SSH_CRYPTO_FILENAME=$(<"$ENV_DIR/GIT_SSH_CRYPTO_FILENAME")
else
    echo "GIT_SSH_CRYPTO_FILENAME not set, defaulting to id_rsa"
    GIT_SSH_CRYPTO_FILENAME="id_rsa"
fi

if [ -f "$ENV_DIR/GIT_SSH_LOG_LEVEL" ]; then
    GIT_SSH_LOG_LEVEL=$(<"$ENV_DIR/GIT_SSH_LOG_LEVEL")
else
    echo "GIT_SSH_LOG_LEVEL not set, defaulting to ERROR"
    GIT_SSH_LOG_LEVEL="ERROR"
fi

# make sure we're in the root of the app dir
cd "$APP_DIR"

# remove existing .gitmodules, we'll check out it again
rm .gitmodules

# # create an empty repo to fetch into
git init -q

# enable sparse checkouts, this will avoid checking out
# all the files in the repo, we'll only check out .gitmodules
git config core.sparseCheckout true
echo ".gitmodules" > .git/info/sparse-checkout

# Function to convert HTTPS to SSH and ensure .git suffix
convert_url_to_ssh() {
    local url="$1"
    # Remove .git if present for normalization
    url="${url%.git}"
    # Convert HTTPS to SSH
    if [[ "$url" =~ ^https://github.com/ ]]; then
        url="git@github.com:${url#https://github.com/}"
    fi
    # Ensure .git suffix
    if [[ ! "$url" =~ \.git$ ]]; then
        url="${url}.git"
    fi
    echo "$url"
}

# # add the repo as a remote and fetch the repo's history
GIT_REMOTE_URL=$(convert_url_to_ssh "$GIT_REPO_URL")
git remote add origin "$GIT_REMOTE_URL"

# # install the ssh key
mkdir -p ~/.ssh
ssh-keyscan -H github.com >> ~/.ssh/known_hosts 2> /dev/null
cp "$ENV_DIR/GIT_SSH_KEY" ~/.ssh/$GIT_SSH_CRYPTO_FILENAME
echo >> ~/.ssh/$GIT_SSH_CRYPTO_FILENAME
chmod 600 ~/.ssh/$GIT_SSH_CRYPTO_FILENAME

# # ignore/hide ssh warnings
echo "Host *" >> ~/.ssh/config
echo "   StrictHostKeyChecking no" >> ~/.ssh/config
echo "   UserKnownHostsFile /dev/null" >> ~/.ssh/config
echo "   LogLevel $GIT_SSH_LOG_LEVEL" >> ~/.ssh/config
echo "-----> Installed SSH key from GIT_SSH_KEY to /app/.ssh/$GIT_SSH_CRYPTO_FILENAME"

# # checkout the revision that's being deployed
git fetch --depth 1 origin -a > /dev/null
git checkout ${SOURCE_VERSION:-master} > /dev/null
echo "-----> Fetched shallow history from $GIT_REPO_URL"

echo "-----> Files in the folder:"

# Converting submodule URLs to SSH and ensuring .git suffix
SUBMODULES=$(git config --file .gitmodules --get-regexp path | awk '{ print $2 }')
for SUBMODULE in $SUBMODULES; do
    URL=$(git config --file .gitmodules --get-regexp "submodule.$SUBMODULE.url" | awk '{ print $2 }')
    SSH_URL=$(convert_url_to_ssh "$URL")
    if [[ "$URL" != "$SSH_URL" ]]; then
        git config --file .gitmodules "submodule.$SUBMODULE.url" "$SSH_URL"
        echo "-----> Converted submodule URL for $SUBMODULE from $URL to $SSH_URL"
    fi
done

echo "-----> Updated .gitmodules file:"
cat .gitmodules


# # initialize all the submodules
echo "-----> Fetching submodules"
git submodule update --init --recursive
echo "-----> Checked out all submodules"
git submodule status | sed 's/^/       * /'